# Copy to .env for local development. On Netlify, set these in Site settings → Environment variables.

# PostgreSQL connection string. Locally: your Homebrew/Docker instance.
# On Netlify: a hosted Postgres (Neon, Supabase, Netlify DB) — use the pooled URL.
DATABASE_URL="postgresql://user@localhost:5432/lifestyle_clothing"

# Storefront reads from: "db" (PostgreSQL via Prisma) or "content" (JSON archive in /content).
# "content" lets the storefront run with no database; admin/checkout/forms require "db".
DATA_SOURCE="db"

# Absolute origin used for canonical URLs, sitemap, OG tags.
NEXT_PUBLIC_SITE_URL="https://lifestyleclothingza.com"

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave empty to disable —
# keep it unset locally so development traffic never reaches the property.
NEXT_PUBLIC_GA_ID=""

# Secret for admin sessions — use a long random value in production (e.g. `openssl rand -hex 32`).
AUTH_SECRET=""

# Initial admin credentials — consumed only by `npm run db:seed`.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# --- Yoco (payments) ---
# Empty = orders recorded without online payment (manual/EFT). Keys from the Yoco
# dashboard → Sell Online → Payment Gateway: sk_test_… to trial, sk_live_… for production.
# Webhook: Yoco POSTs to {NEXT_PUBLIC_SITE_URL}/api/yoco/webhook (must be public HTTPS).
# Register it with `npm run yoco:register-webhook`, then paste the whsec_… it prints here.
YOCO_SECRET_KEY=""
YOCO_WEBHOOK_SECRET=""

# --- The Courier Guy (delivery, via Shiplogic API) ---
# Empty key = flat R99 / free over R500. With a key: live rates at checkout and
# one-click shipment booking (with tracking) from the admin order page.
# The COLLECTION_* address is where the courier picks parcels up.
COURIER_GUY_API_KEY=""
COURIER_GUY_COLLECTION_STREET=""
COURIER_GUY_COLLECTION_SUBURB=""
COURIER_GUY_COLLECTION_CITY=""
COURIER_GUY_COLLECTION_PROVINCE="Gauteng"
COURIER_GUY_COLLECTION_POSTAL_CODE=""
