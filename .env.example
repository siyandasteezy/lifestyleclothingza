# Copy to .env for local development. On Netlify, set these in Site settings → Environment variables.

# PostgreSQL connection string. Locally: your Homebrew/Docker instance.
# On Netlify: a hosted Postgres (Neon, Supabase, Netlify DB) — use the pooled URL.
DATABASE_URL="postgresql://user@localhost:5432/lifestyle_clothing"

# Storefront reads from: "db" (PostgreSQL via Prisma) or "content" (JSON archive in /content).
# "content" lets the storefront run with no database; admin/checkout/forms require "db".
DATA_SOURCE="db"

# Absolute origin used for canonical URLs, sitemap, OG tags.
NEXT_PUBLIC_SITE_URL="https://lifestyleclothingza.com"

# Secret for admin sessions — use a long random value in production (e.g. `openssl rand -hex 32`).
AUTH_SECRET=""

# Initial admin credentials — consumed only by `npm run db:seed`.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
